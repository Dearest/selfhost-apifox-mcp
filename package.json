{
  "name": "selfhost-apifox-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Apifox private deployment MCP server",
  "main": "dist/src/index.js",
  "bin": {
    "selfhost-apifox-mcp": "dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm check && pnpm test && pnpm build"
  },
  "keywords": [
    "mcp",
    "apifox",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "axios-mock-adapter": "^2.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
