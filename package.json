  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "axios-mock-adapter": "^2.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
