{
  "name": "apifox-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Apifox private deployment MCP server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
